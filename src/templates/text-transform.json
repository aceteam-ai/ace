{
  "name": "Text Transform",
  "description": "Transform text with an LLM using custom instructions.",
  "input_node": {
    "id": "input",
    "type": "Input",
    "params": {
      "fields": {
        "text": { "type": "string", "title": "Input Text", "description": "The text to transform" },
        "instructions": { "type": "string", "title": "Instructions", "description": "Transformation instructions" }
      }
    }
  },
  "output_node": {
    "id": "output",
    "type": "Output",
    "params": {
      "fields": {
        "result": { "type": "string", "title": "Result", "description": "The transformed text" }
      }
    }
  },
  "inner_nodes": [
    {
      "id": "transform",
      "type": "LLM",
      "params": {
        "model": "gpt-4o-mini",
        "system_prompt": "Transform the text according to the given instructions."
      }
    }
  ],
  "edges": [
    { "source_id": "input", "source_key": "text", "target_id": "transform", "target_key": "prompt" },
    { "source_id": "transform", "source_key": "response", "target_id": "output", "target_key": "result" }
  ]
}
