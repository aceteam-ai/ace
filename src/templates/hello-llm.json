{
  "name": "Hello LLM",
  "description": "Send a prompt to an LLM and get a response.",
  "input_node": {
    "id": "input",
    "type": "Input",
    "params": {
      "fields": {
        "prompt": { "type": "string", "title": "Prompt", "description": "The prompt to send to the LLM" }
      }
    }
  },
  "output_node": {
    "id": "output",
    "type": "Output",
    "params": {
      "fields": {
        "response": { "type": "string", "title": "Response", "description": "The LLM response" }
      }
    }
  },
  "inner_nodes": [
    {
      "id": "llm",
      "type": "LLM",
      "params": {
        "model": "gpt-4o-mini"
      }
    }
  ],
  "edges": [
    { "source_id": "input", "source_key": "prompt", "target_id": "llm", "target_key": "prompt" },
    { "source_id": "llm", "source_key": "response", "target_id": "output", "target_key": "response" }
  ]
}
