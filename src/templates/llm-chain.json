{
  "name": "LLM Chain",
  "description": "Two-step LLM pipeline: draft then refine.",
  "input_node": {
    "id": "input",
    "type": "Input",
    "params": {
      "fields": {
        "prompt": { "type": "string", "title": "Prompt", "description": "The initial prompt for the draft" }
      }
    }
  },
  "output_node": {
    "id": "output",
    "type": "Output",
    "params": {
      "fields": {
        "response": { "type": "string", "title": "Refined Response", "description": "The refined LLM response" }
      }
    }
  },
  "inner_nodes": [
    {
      "id": "draft",
      "type": "LLM",
      "params": {
        "model": "gpt-4o-mini",
        "system_prompt": "You are a helpful assistant. Write a first draft based on the prompt."
      }
    },
    {
      "id": "refine",
      "type": "LLM",
      "params": {
        "model": "gpt-4o-mini",
        "system_prompt": "You are an editor. Refine and improve the following draft. Make it clearer and more concise."
      }
    }
  ],
  "edges": [
    { "source_id": "input", "source_key": "prompt", "target_id": "draft", "target_key": "prompt" },
    { "source_id": "draft", "source_key": "response", "target_id": "refine", "target_key": "prompt" },
    { "source_id": "refine", "source_key": "response", "target_id": "output", "target_key": "response" }
  ]
}
