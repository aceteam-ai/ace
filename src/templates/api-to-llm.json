{
  "name": "API to LLM",
  "description": "Fetch a URL then summarize the content with an LLM.",
  "input_node": {
    "id": "input",
    "type": "Input",
    "params": {
      "fields": {
        "url": { "type": "string", "title": "URL", "description": "The URL to fetch and summarize" }
      }
    }
  },
  "output_node": {
    "id": "output",
    "type": "Output",
    "params": {
      "fields": {
        "summary": { "type": "string", "title": "Summary", "description": "LLM summary of the fetched content" }
      }
    }
  },
  "inner_nodes": [
    {
      "id": "fetch",
      "type": "APICall",
      "params": {
        "method": "GET"
      }
    },
    {
      "id": "summarize",
      "type": "LLM",
      "params": {
        "model": "gpt-4o-mini",
        "system_prompt": "Summarize the following content concisely."
      }
    }
  ],
  "edges": [
    { "source_id": "input", "source_key": "url", "target_id": "fetch", "target_key": "url" },
    { "source_id": "fetch", "source_key": "response_body", "target_id": "summarize", "target_key": "prompt" },
    { "source_id": "summarize", "source_key": "response", "target_id": "output", "target_key": "summary" }
  ]
}
